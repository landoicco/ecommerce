# Frontend
FRONTEND_URL=http://localhost:3000
# Backend
BACKEND_BASE_URL=http://localhost:8080
BACKEND_ACTUATOR_URL=${BACKEND_BASE_URL}/actuator/health
BACKEND_PRODUCTS_URL=${BACKEND_BASE_URL}/api/products
BACKEND_HEALTHCHECK_CMD="wget -qO- ${BACKEND_ACTUATOR_URL} | grep UP || exit 1"
# Database
DB_URL=jdbc:mariadb://database:3306/ecommercedb
DB_USER=root
DB_PASSWORD=root
DB_NAME=ecommercedb
DB_HEALTHCHECK_CMD="/usr/bin/mariadb --user=${DB_USER} --password=${DB_PASSWORD} --execute \"SHOW DATABASES;\""
